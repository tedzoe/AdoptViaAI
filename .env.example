# AdoptviaAI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Required ───────────────────────────────────────────────────────────────────

# Your Anthropic API key — get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# ── Model defaults (optional) ──────────────────────────────────────────────────

# Default model: haiku | sonnet | opus  (default: haiku)
# DEFAULT_MODEL=haiku

# Max output tokens per API response  (default: 2048)
# MAX_TOKENS=2048

# Warn in the cost line when session spend exceeds this USD amount  (default: 0.10)
# COST_WARNING_THRESHOLD=0.10

# ── Phase 5: Safety & Budget (optional) ───────────────────────────────────────

# Hard USD cap per session — avai refuses API calls once this is reached  (default: 1.00)
# AVAI_MAX_USD=1.00

# Rate limit: max API requests per minute  (default: 30)
# AVAI_MAX_RPM=30
